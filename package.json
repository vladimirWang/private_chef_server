{
  "name": "my-app",
  "scripts": {
    "dev": "bunx dotenv -e .env.dev -- bun run --hot src/index.ts",
    "db:generate": "bunx dotenv -e .env.dev -- prisma generate",
    "db:migrate": "bunx dotenv -e .env.dev -- prisma migrate dev"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "7.4.2",
    "ali-oss": "^6.23.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.15",
    "pino": "^10.3.1",
    "protobufjs": "^8.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/bun": "latest",
    "dotenv-cli": "^11.0.0",
    "prisma": "7.4.2"
  }
}